<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Amir Raza | Digital Marketing & Shopify Store Development</title>
  <meta name="description" content="Portfolio website for Amir Raza — Digital Marketing Strategist and Shopify Store Developer building high-converting eCommerce experiences." />
  <style>
    :root{
      --bg:#08111f;
      --bg-2:#0d1830;
      --surface:rgba(16,27,50,.72);
      --surface-2:rgba(255,255,255,.06);
      --card:#0f1b33;
      --line:rgba(255,255,255,.09);
      --text:#edf4ff;
      --muted:#98a8c7;
      --primary:#7c3aed;
      --primary-2:#06b6d4;
      --accent:#22c55e;
      --danger:#fb7185;
      --shadow:0 20px 60px rgba(0,0,0,.35);
      --radius:22px;
      --radius-sm:14px;
      --max:1200px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at 20% 20%, rgba(124,58,237,.22), transparent 28%),
        radial-gradient(circle at 80% 15%, rgba(6,182,212,.18), transparent 26%),
        radial-gradient(circle at 50% 90%, rgba(34,197,94,.08), transparent 24%),
        linear-gradient(180deg, #08111f 0%, #091326 35%, #07101d 100%);
      min-height:100vh;
      overflow-x:hidden;
    }

    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    button,input,select,textarea{font:inherit}
    .container{width:min(var(--max), calc(100% - 2rem));margin:0 auto}
    .section{padding:100px 0;position:relative}
    .section-header{max-width:700px;margin:0 auto 48px;text-align:center}
    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 14px;
      border:1px solid rgba(255,255,255,.1);
      background:rgba(255,255,255,.04);
      color:#d6e4ff;
      border-radius:999px;
      font-size:.9rem;
      letter-spacing:.02em;
      backdrop-filter: blur(12px);
    }
    .eyebrow::before{
      content:"";
      width:8px;height:8px;border-radius:50%;
      background:linear-gradient(135deg,var(--primary),var(--primary-2));
      box-shadow:0 0 18px rgba(124,58,237,.75);
    }
    h1,h2,h3,h4,p{margin:0}
    h1{
      font-size:clamp(2.8rem, 7vw, 5.4rem);
      line-height:.95;
      letter-spacing:-.05em;
      font-weight:800;
    }
    h2{
      font-size:clamp(2rem, 4.5vw, 3.4rem);
      line-height:1;
      letter-spacing:-.04em;
      font-weight:800;
    }
    h3{
      font-size:1.15rem;
      font-weight:700;
      letter-spacing:-.02em;
    }
    p{
      color:var(--muted);
      line-height:1.75;
      font-size:1.02rem;
    }

    .bg-grid{
      position:fixed;
      inset:0;
      background-image:
        linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
      background-size:40px 40px;
      mask-image:radial-gradient(circle at center, black 45%, transparent 85%);
      opacity:.22;
      pointer-events:none;
      z-index:-2;
    }

    .noise{
      position:fixed;
      inset:0;
      background-image: radial-gradient(rgba(255,255,255,.05) 1px, transparent 1px);
      background-size: 4px 4px;
      opacity:.045;
      pointer-events:none;
      z-index:-1;
    }

    .site-header{
      position:sticky;
      top:0;
      z-index:40;
      backdrop-filter: blur(16px);
      background:rgba(8,17,31,.55);
      border-bottom:1px solid rgba(255,255,255,.06);
    }
    .nav{
      display:flex;
      align-items:center;
      justify-content:space-between;
      min-height:78px;
      gap:20px;
    }
    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      font-weight:800;
      letter-spacing:-.03em;
    }
    .brand-mark{
      width:42px;height:42px;border-radius:14px;
      display:grid;place-items:center;
      background:linear-gradient(135deg,var(--primary),var(--primary-2));
      box-shadow:0 12px 30px rgba(124,58,237,.35);
      color:white;font-weight:800;
    }
    .brand small{
      display:block;
      color:var(--muted);
      font-weight:600;
      font-size:.75rem;
      letter-spacing:.03em;
      margin-top:2px;
    }
    .nav-links{
      display:flex;
      align-items:center;
      gap:10px;
      list-style:none;
      margin:0;
      padding:0;
    }
    .nav-links a{
      color:#d8e5ff;
      padding:11px 14px;
      border-radius:12px;
      font-size:.95rem;
      transition:.25s ease;
    }
    .nav-links a:hover,
    .nav-links a.active{
      background:rgba(255,255,255,.06);
      color:#fff;
    }
    .nav-cta{
      display:flex;
      align-items:center;
      gap:12px;
    }
    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      min-height:52px;
      padding:0 20px;
      border:none;
      border-radius:16px;
      font-weight:700;
      cursor:pointer;
      transition:transform .25s ease, box-shadow .25s ease, background .25s ease, border-color .25s ease;
      white-space:nowrap;
    }
    .btn:hover{transform:translateY(-2px)}
    .btn-primary{
      color:#fff;
      background:linear-gradient(135deg,var(--primary),var(--primary-2));
      box-shadow:0 18px 35px rgba(98,80,240,.25);
    }
    .btn-secondary{
      color:#fff;
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.08);
    }
    .btn-ghost{
      background:transparent;
      border:1px solid rgba(255,255,255,.1);
      color:#dbe6ff;
    }

    .menu-toggle{
      display:none;
      width:48px;height:48px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(255,255,255,.04);
      color:white;
      cursor:pointer;
    }
    .menu-toggle span{
      display:block;
      width:20px;height:2px;
      background:#fff;
      margin:4px auto;
      transition:.25s ease;
      border-radius:2px;
    }

    .hero{
      padding:90px 0 70px;
      position:relative;
      overflow:hidden;
    }
    .hero-wrap{
      display:grid;
      grid-template-columns:1.1fr .9fr;
      gap:42px;
      align-items:center;
    }
    .hero-copy p{
      max-width:640px;
      margin:24px 0 30px;
      font-size:1.08rem;
    }
    .hero-title-gradient{
      background:linear-gradient(90deg,#fff 0%, #d7c8ff 38%, #9de7f7 80%, #fff 100%);
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
      background-clip:text;
      color:transparent;
    }
    .hero-actions{
      display:flex;
      flex-wrap:wrap;
      gap:14px;
      margin-bottom:26px;
    }
    .hero-meta{
      display:flex;
      flex-wrap:wrap;
      gap:14px;
    }
    .chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:10px 14px;
      border-radius:999px;
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.08);
      color:#dce7ff;
      font-size:.92rem;
      backdrop-filter: blur(12px);
    }
    .chip-dot{
      width:8px;height:8px;border-radius:50%;background:var(--accent);
      box-shadow:0 0 16px rgba(34,197,94,.7);
    }

    .hero-visual{
      position:relative;
      min-height:580px;
    }
    .glass-panel{
      position:absolute;
      border:1px solid rgba(255,255,255,.08);
      background:linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.04));
      box-shadow:var(--shadow);
      backdrop-filter: blur(20px);
      border-radius:30px;
      overflow:hidden;
    }
    .main-dashboard{
      inset:40px 0 0 50px;
      padding:22px;
    }
    .panel-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      margin-bottom:18px;
    }
    .panel-dots{display:flex;gap:6px}
    .panel-dots span{
      width:10px;height:10px;border-radius:50%;
      background:rgba(255,255,255,.22);
    }
    .panel-title{font-size:.95rem;color:#dce7ff;font-weight:700}
    .dashboard-grid{
      display:grid;
      grid-template-columns:1.15fr .85fr;
      gap:16px;
      height:calc(100% - 36px);
    }
    .store-preview,.analytics{
      background:rgba(9,16,31,.55);
      border:1px solid rgba(255,255,255,.06);
      border-radius:24px;
      padding:18px;
    }
    .preview-screen{
      height:100%;
      border-radius:18px;
      background:
        linear-gradient(180deg, rgba(124,58,237,.2), rgba(6,182,212,.06)),
        rgba(255,255,255,.03);
      border:1px solid rgba(255,255,255,.06);
      padding:16px;
      display:flex;
      flex-direction:column;
      gap:14px;
    }
    .topbar,.bars,.cards-mini,.product-grid{display:grid;gap:12px}
    .topbar{grid-template-columns:1.5fr .7fr}
    .bar{
      height:14px;border-radius:999px;background:rgba(255,255,255,.12);
      overflow:hidden;position:relative;
    }
    .bar::after{
      content:"";position:absolute;inset:0;border-radius:999px;
      background:linear-gradient(90deg,var(--primary),var(--primary-2));
      width:60%;
    }
    .hero-banner{
      height:150px;
      border-radius:20px;
      background:
        radial-gradient(circle at 70% 25%, rgba(255,255,255,.32), transparent 20%),
        linear-gradient(135deg, rgba(124,58,237,.65), rgba(6,182,212,.55));
      position:relative;
      overflow:hidden;
    }
    .hero-banner::after{
      content:"";
      position:absolute;
      width:120px;height:120px;border-radius:24px;
      background:rgba(255,255,255,.18);
      right:18px;bottom:-10px;
      transform:rotate(22deg);
      box-shadow:0 20px 40px rgba(0,0,0,.15);
    }
    .product-grid{
      grid-template-columns:repeat(2,1fr);
      flex:1;
    }
    .product-card{
      border-radius:18px;
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.06);
      padding:12px;
      display:flex;flex-direction:column;gap:10px;
    }
    .product-thumb{
      height:72px;border-radius:12px;
      background:linear-gradient(135deg, rgba(255,255,255,.12), rgba(255,255,255,.04));
    }
    .product-card .bar{height:10px}
    .product-card .bar::after{width:75%}
    .analytics{
      display:flex;
      flex-direction:column;
      gap:14px;
    }
    .stat-card{
      padding:16px;
      border-radius:20px;
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.06);
    }
    .stat-label{font-size:.86rem;color:#bfd0ef}
    .stat-value{
      margin-top:8px;
      font-size:2rem;
      font-weight:800;
      letter-spacing:-.04em;
    }
    .chart{
      flex:1;
      border-radius:20px;
      background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
      border:1px solid rgba(255,255,255,.06);
      position:relative;
      overflow:hidden;
      min-height:160px;
    }
    .chart svg{position:absolute;inset:0;width:100%;height:100%}
    .floating-card{
      position:absolute;
      padding:16px 18px;
      border-radius:22px;
      background:linear-gradient(180deg, rgba(255,255,255,.16), rgba(255,255,255,.06));
      border:1px solid rgba(255,255,255,.08);
      box-shadow:var(--shadow);
      backdrop-filter:blur(16px);
      animation:float 6s ease-in-out infinite;
    }
    .floating-card strong{
      display:block;
      font-size:1.25rem;
      margin-top:4px;
      letter-spacing:-.03em;
    }
    .card-a{top:0;left:0;animation-delay:0s}
    .card-b{right:0;bottom:40px;animation-delay:1.5s}
    .card-c{left:16px;bottom:10px;animation-delay:3s}
    @keyframes float{
      0%,100%{transform:translateY(0)}
      50%{transform:translateY(-12px)}
    }

    .stats-row{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:18px;
      margin-top:34px;
    }
    .metric{
      padding:22px;
      border-radius:22px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.08);
      backdrop-filter: blur(12px);
    }
    .metric strong{
      display:block;
      font-size:2rem;
      letter-spacing:-.04em;
      margin-bottom:8px;
    }

    .services-grid{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:18px;
    }
    .service-card{
      padding:26px;
      border-radius:26px;
      background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
      border:1px solid rgba(255,255,255,.08);
      box-shadow:var(--shadow);
      transition:transform .25s ease, border-color .25s ease, box-shadow .25s ease;
      position:relative;
      overflow:hidden;
    }
    .service-card:hover{
      transform:translateY(-6px);
      border-color:rgba(255,255,255,.18);
      box-shadow:0 22px 60px rgba(0,0,0,.38);
    }
    .service-card::before{
      content:"";
      position:absolute;
      inset:auto auto -30px -10px;
      width:120px;height:120px;border-radius:999px;
      background:radial-gradient(circle, rgba(124,58,237,.25), transparent 65%);
      pointer-events:none;
    }
    .icon{
      width:52px;height:52px;border-radius:16px;
      display:grid;place-items:center;
      margin-bottom:18px;
      background:linear-gradient(135deg, rgba(124,58,237,.22), rgba(6,182,212,.16));
      border:1px solid rgba(255,255,255,.08);
      color:#fff;
    }
    .service-card p{margin:12px 0 18px}
    .service-list{
      margin:0;padding:0;list-style:none;display:grid;gap:10px;
    }
    .service-list li{
      display:flex;gap:10px;align-items:flex-start;
      color:#dbe6ff;font-size:.95rem;
    }
    .service-list li::before{
      content:"";
      width:8px;height:8px;margin-top:8px;border-radius:50%;
      background:linear-gradient(135deg,var(--primary),var(--primary-2));
      flex:none;
    }

    .filters{
      display:flex;
      justify-content:center;
      flex-wrap:wrap;
      gap:12px;
      margin-bottom:28px;
    }
    .filter-btn{
      min-height:46px;
      padding:0 16px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(255,255,255,.04);
      color:#dfe9ff;
      cursor:pointer;
      transition:.25s ease;
    }
    .filter-btn.active,
    .filter-btn:hover{
      background:linear-gradient(135deg,var(--primary),var(--primary-2));
      border-color:transparent;
      color:#fff;
    }

    .projects-grid{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:20px;
    }
    .project-card{
      border-radius:26px;
      overflow:hidden;
      background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
      border:1px solid rgba(255,255,255,.08);
      box-shadow:var(--shadow);
      transition:transform .25s ease, opacity .25s ease, scale .25s ease;
    }
    .project-card.hide{
      opacity:.18;
      pointer-events:none;
      transform:scale(.96);
      display:none;
    }
    .project-card:hover{transform:translateY(-6px)}
    .project-visual{
      position:relative;
      padding:18px;
      min-height:230px;
      background:
        radial-gradient(circle at 85% 15%, rgba(255,255,255,.22), transparent 20%),
        linear-gradient(135deg, rgba(124,58,237,.24), rgba(6,182,212,.12));
      border-bottom:1px solid rgba(255,255,255,.08);
    }
    .device{
      height:100%;
      min-height:194px;
      border-radius:22px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(8,17,31,.62);
      backdrop-filter: blur(10px);
      padding:14px;
      display:flex;
      flex-direction:column;
      gap:12px;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.05);
    }
    .device-row{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:10px;
    }
    .mini-box{
      height:68px;border-radius:14px;
      background:linear-gradient(135deg, rgba(255,255,255,.10), rgba(255,255,255,.04));
      border:1px solid rgba(255,255,255,.05);
    }
    .project-body{
      padding:22px;
      display:grid;
      gap:16px;
    }
    .project-tags{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
    }
    .tag{
      padding:7px 10px;
      border-radius:999px;
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.08);
      font-size:.78rem;
      color:#dbe6ff;
    }
    .result{
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:14px 16px;
      border-radius:18px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.06);
      gap:14px;
    }
    .result strong{
      font-size:1.18rem;
      letter-spacing:-.03em;
      color:#fff;
    }

    .about-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:22px;
      align-items:stretch;
    }
    .about-card,.process-card{
      padding:30px;
      border-radius:30px;
      background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
      border:1px solid rgba(255,255,255,.08);
      box-shadow:var(--shadow);
    }
    .about-card p{margin:18px 0 24px}
    .about-points{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:12px;
    }
    .about-points .point{
      padding:16px;
      border-radius:18px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.06);
    }
    .process{
      display:grid;
      gap:16px;
      margin-top:16px;
    }
    .step{
      display:grid;
      grid-template-columns:auto 1fr;
      gap:14px;
      align-items:flex-start;
      padding:16px;
      border-radius:20px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.06);
    }
    .step-number{
      width:42px;height:42px;border-radius:14px;
      display:grid;place-items:center;
      background:linear-gradient(135deg,var(--primary),var(--primary-2));
      font-weight:800;
      box-shadow:0 12px 30px rgba(124,58,237,.28);
    }

    .testimonials-wrap{
      position:relative;
      overflow:hidden;
      border-radius:30px;
      border:1px solid rgba(255,255,255,.08);
      background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
      box-shadow:var(--shadow);
    }
    .slides{
      display:flex;
      transition:transform .5s ease;
    }
    .slide{
      min-width:100%;
      padding:34px;
      display:grid;
      grid-template-columns:1.05fr .95fr;
      gap:24px;
      align-items:center;
    }
    .quote{
      font-size:1.3rem;
      line-height:1.6;
      color:#eff5ff;
      letter-spacing:-.02em;
    }
    .author{
      margin-top:20px;
      display:flex;align-items:center;gap:14px;
    }
    .avatar{
      width:54px;height:54px;border-radius:18px;
      display:grid;place-items:center;
      font-weight:800;
      background:linear-gradient(135deg,var(--primary),var(--primary-2));
    }
    .testimonial-side{
      padding:24px;
      border-radius:24px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.06);
      display:grid;
      gap:14px;
    }
    .mini-metric{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:14px 16px;
      border-radius:18px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.06);
    }
    .slider-controls{
      display:flex;
      justify-content:center;
      gap:10px;
      margin-top:20px;
    }
    .dot{
      width:12px;height:12px;border-radius:50%;
      background:rgba(255,255,255,.2);
      border:none;
      cursor:pointer;
      transition:.25s ease;
    }
    .dot.active{
      width:34px;border-radius:999px;
      background:linear-gradient(135deg,var(--primary),var(--primary-2));
    }

    .faq-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:18px;
    }
    .faq-item{
      border-radius:22px;
      background:linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.03));
      border:1px solid rgba(255,255,255,.08);
      overflow:hidden;
    }
    .faq-btn{
      width:100%;
      background:none;
      border:none;
      color:#fff;
      padding:22px;
      text-align:left;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:16px;
      cursor:pointer;
      font-weight:700;
    }
    .faq-btn span:last-child{
      width:30px;height:30px;border-radius:10px;
      display:grid;place-items:center;
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.06);
      flex:none;
    }
    .faq-answer{
      max-height:0;
      overflow:hidden;
      transition:max-height .3s ease;
      padding:0 22px;
    }
